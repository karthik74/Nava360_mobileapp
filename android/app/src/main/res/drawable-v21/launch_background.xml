<?xml version="1.0" encoding="utf-8"?>
<!-- Modify this file to customize your launch splash screen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Force white (not colorBackground) so dark mode doesn't flash a dark
         launch window before the white Flutter loader. -->
    <item android:drawable="@android:color/white" />

    <!-- Brand logo centered — blends the OS launch window into the Flutter
         branded loader (no blank flash). The 1254px source lives in the plain
         drawable bucket (mdpi baseline), so without an explicit size the OS
         density-scales it 2-3x and it overflows/clips off-centre. Pin it to a
         fixed 240dp box (matching the Flutter loader) and centre that box. -->
    <item
        android:width="240dp"
        android:height="240dp"
        android:gravity="center">
        <!-- No bitmap gravity → the (square) image SCALES DOWN to fill this
             240dp box instead of drawing at full intrinsic size and clipping. -->
        <bitmap android:src="@drawable/launch_image" />
    </item>
</layer-list>
